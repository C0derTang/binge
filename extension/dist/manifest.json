{
  "manifest_version": 3,
  "name": "Binge",
  "version": "1.0.0",
  "description": "Dating app that matches you based on Instagram Reels you watch",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["*://www.instagram.com/*"],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
